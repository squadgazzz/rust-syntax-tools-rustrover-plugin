<idea-plugin>
    <id>com.github.squadgazzz.rustsyntaxtoolsrustroverplugin</id>
    <name>Rust Enhanced Syntax Highlighting</name>
    <vendor>squadgazzz</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.rust</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceImplementation="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterConfigurable"
            id="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterConfigurable"
            displayName="Rust Enhanced Syntax Highlighting"/>
        <codeInsight.lineMarkerProvider
            language="Rust"
            implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncLineMarkerProvider"/>
        <annotator
            language="Rust"
            implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncAnnotator"/>
        <colorSettingsPage
            implementation="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncColorSettingsPage"/>
        <codeInsight.lineMarkerProvider
            language="Rust"
            implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.EarlyReturnLineMarkerProvider"/>
        <annotator
            language="Rust"
            implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.EarlyReturnAnnotator"/>
        <colorSettingsPage
            implementation="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.EarlyReturnColorSettingsPage"/>
        <codeInsight.declarativeInlayProvider
            language="Rust"
            implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncInlayHintsProvider"
            isEnabledByDefault="true"
            group="OTHER_GROUP"
            providerId="rust.async.highlighter.inlay"
            bundle="messages.RustAsyncHighlighterBundle"
            nameKey="rust.async.inlay.provider.name"/>
    </extensions>
</idea-plugin>
