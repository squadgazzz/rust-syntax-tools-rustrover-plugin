<idea-plugin>
    <id>com.github.squadgazzz.rustsyntaxtoolsrustroverplugin</id>
    <name>Rust Async Highlighter</name>
    <vendor>squadgazzz</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.rust</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceImplementation="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterConfigurable"
            id="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterConfigurable"
            displayName="Rust Async Highlighter"/>
        <codeInsight.lineMarkerProvider
            language="Rust"
            implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncLineMarkerProvider"/>
        <annotator
            language="Rust"
            implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncAnnotator"/>
        <colorSettingsPage
            implementation="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncColorSettingsPage"/>
        <codeInsight.inlayHintsProvider
            language="Rust"
            implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncInlayHintsProvider"/>
    </extensions>
</idea-plugin>
