<idea-plugin>
  <idea-version since-build="253" />
  <change-notes><![CDATA[<h3>Added</h3>

<ul><li>Initial scaffold created from <a href="https://github.com/JetBrains/intellij-platform-plugin-template">IntelliJ Platform Plugin Template</a></li></ul>]]></change-notes>
  <description><![CDATA[<p>Enhances Rust syntax highlighting in RustRover with visual indicators for async calls
(.await, async fn, spawn) and early return points (return, ?, unwrap, panic). Features
gutter icons, inline border highlighting, and inlay hints — each independently configurable.</p>]]></description>
  <version>0.0.1</version>
  <id>com.github.squadgazzz.rustsyntaxtoolsrustroverplugin</id>
  <name>Rust Enhanced Syntax Highlighting</name>
  <vendor>squadgazzz</vendor>
  <depends>com.intellij.modules.platform</depends>
  <depends>com.jetbrains.rust</depends>
  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterSettings" />
    <applicationConfigurable parentId="tools" instance="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterConfigurable" id="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.settings.AsyncHighlighterConfigurable" displayName="Rust Enhanced Syntax Highlighting" />
    <codeInsight.lineMarkerProvider language="Rust" implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncLineMarkerProvider" />
    <annotator language="Rust" implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncAnnotator" />
    <colorSettingsPage implementation="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncColorSettingsPage" />
    <codeInsight.lineMarkerProvider language="Rust" implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.EarlyReturnLineMarkerProvider" />
    <annotator language="Rust" implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.EarlyReturnAnnotator" />
    <colorSettingsPage implementation="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.EarlyReturnColorSettingsPage" />
    <codeInsight.declarativeInlayProvider language="Rust" implementationClass="com.github.squadgazzz.rustsyntaxtoolsrustroverplugin.providers.AsyncInlayHintsProvider" isEnabledByDefault="true" group="OTHER_GROUP" providerId="rust.async.highlighter.inlay" bundle="messages.RustAsyncHighlighterBundle" nameKey="rust.async.inlay.provider.name" />
  </extensions>
</idea-plugin>
